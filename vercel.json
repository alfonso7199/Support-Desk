{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "server.py": {
      "maxDuration": 60,
      "includeFiles": [
        "web/**",
        "synthetic_data/**"
      ],
      "excludeFiles": [
        "**/__pycache__/**",
        "**/*.pyc",
        ".venv/**",
        "venv/**"
      ]
    }
  }
}
